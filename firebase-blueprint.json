{
  "entities": {
    "Plan": {
      "title": "Plan",
      "description": "A recurring structural plan or function.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Name of the plan" },
        "owner": { "type": "string", "description": "Owner of the plan" },
        "outcome": { "type": "string", "description": "Expected outcome" },
        "cadence": { "type": "string", "enum": ["weekly", "monthly", "quarterly"] },
        "risks": { "type": "string", "description": "Initial risks" },
        "reportingMetric": { "type": "string", "description": "Metric to track" },
        "status": { "type": "string", "enum": ["green", "yellow", "red"] },
        "nextReminder": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "owner", "outcome", "cadence", "reportingMetric"]
    }
  },
  "firestore": {
    "/plans/{planId}": {
      "schema": { "$ref": "Plan" },
      "description": "Collection of recurring plans."
    }
  }
}
